k
const NAV_LINKS = ["Permisos", "Salarios", "Sanidad", "Pensiones", "Calculadora", "Coches"];

const AREAS = [
  { icon: "📋", title: "Permisos de residencia", desc: "B, C, G y L explicados de forma clara.", page: "permisos" },
  { icon: "💼", title: "Empleo", desc: "Salarios, contratos y el 13.º mes", page: "salarios" },
  { icon: "🏠", title: "Vivienda", desc: "Cómo buscar piso y entender el contrato" },
  { icon: "🚗", title: "Coches", desc: "Comprar, matricular o traer tu coche", page: "coches" },
  { icon: "⚕️", title: "Sanidad", desc: "LAMal, franquicia y cómo ir al médico", page: "sanidad" },
  { icon: "🧮", title: "Calculadora Bruto → Neto", desc: "26 cantones · Quellensteuer oficial · BVG por edad" },
  { icon: "📊", title: "Impuestos", desc: "Quellensteuer, IRPF y declaración" },
  { icon: "🏛️", title: "Pensiones", desc: "Los 3 pilares y cómo recuperar el 2.º", page: "pensiones" },
  { icon: "✈️", title: "Vuelta a España", desc: "Baja consular y trámites al volver" },
];

const SALARIOS = [
  { rol: "Piloto (capitán)", sector: "Aerolínea", rango: "150–180k" },
  { rol: "Médico adjunto", sector: "Hospital / clínica", rango: "105–120k" },
  { rol: "Profesor/a", sector: "Escuela pública", rango: "85–90k" },
  { rol: "Albañil", sector: "CCT construcción", rango: "67–72k" },
  { rol: "Hostelería", sector: "Cocinero/a, camarero/a", rango: "42–58k" },
  { rol: "Limpieza / Servicios", sector: "Convenio colectivo", rango: "38–50k" },
];

const TESTIMONIOS = [
  { texto: "Llegué sin saber nada del sistema de permisos. Esta guía me ahorró semanas de búsqueda y no cometí ningún error en los primeros trámites.", nombre: "Carlos M.", cargo: "Ingeniero en Zúrich desde 2023" },
  { texto: "No sabía que el seguro médico era obligatorio desde el primer día. Gracias a esta información lo contraté antes de llegar.", nombre: "Laura S.", cargo: "Enfermera en Berna desde 2022" },
  { texto: "Lo del segundo pilar me pareció magia. Cuando volví a España, recuperé más de 18.000 CHF que había acumulado en 4 años.", nombre: "Marcos R.", cargo: "Hostelería en Ginebra, volvió en 2024" },
];

export default function Swissrus({ onNavigate }) {
  const [scrolled, setScrolled] = useState(false);
  const [visible, setVisible] = useState(false);

  useEffect(() => {
    setVisible(true);
    const handleScroll = () => setScrolled(window.scrollY > 40);
    window.addEventListener("scroll", handleScroll);
    return () => window.removeEventListener("scroll", handleScroll);
  }, []);

  return (
    <div style={{ fontFamily: "'Georgia', 'Times New Roman', serif", background: "#faf9f7", color: "#1a1a1a", minHeight: "100vh" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Source+Sans+3:wght@300;400;600&display=swap');

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body { background: #faf9f7; }

        .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0 2rem; height: 60px; display: flex; align-items: center; justify-content: space-between; transition: all 0.3s ease; background: ${scrolled ? "rgba(250,249,247,0.96)" : "transparent"}; backdrop-filter: ${scrolled ? "blur(8px)" : "none"}; border-bottom: ${scrolled ? "1px solid rgba(0,0,0,0.08)" : "none"}; }

        .nav-logo { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; letter-spacing: -0.02em; color: #1a1a1a; }
        .nav-logo span { color: #c0392b; }

        .nav-links { display: flex; gap: 1.5rem; }
        .nav-links a { font-family: 'Source Sans 3', sans-serif; font-size: 0.85rem; font-weight: 400; color: #555; text-decoration: none; letter-spacing: 0.04em; text-transform: uppercase; transition: color 0.2s; }
        .nav-links a:hover { color: #c0392b; }
        .nav-cta { background: #c0392b; color: white !important; padding: 0.4rem 1rem; border-radius: 2px; font-weight: 600 !important; }
        .nav-cta:hover { background: #a93226; color: white !important; }

        .hero { min-height: 100vh; display: flex; align-items: center; padding: 6rem 2rem 4rem; max-width: 1100px; margin: 0 auto; }
        .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; width: 100%; }

        .hero-text { opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : "30px"}); transition: all 0.8s ease; }
        .hero-eyebrow { font-family: 'Source Sans 3', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #c0392b; margin-bottom: 1.2rem; display: flex; align-items: center; gap: 0.5rem; }
        .hero-eyebrow::before { content: ""; display: inline-block; width: 24px; height: 1px; background: #c0392b; }
        .hero-title { font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 5vw, 4.2rem); font-weight: 900; line-height: 1.08; letter-spacing: -0.03em; margin-bottom: 1.5rem; color: #111; }
        .hero-title em { font-style: italic; color: #c0392b; }
        .hero-subtitle { font-family: 'Source Sans 3', sans-serif; font-size: 1.05rem; font-weight: 300; line-height: 1.7; color: #555; margin-bottom: 2.5rem; max-width: 420px; }

        .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
        .btn-primary { background: #c0392b; color: white; padding: 0.9rem 2rem; font-family: 'Source Sans 3', sans-serif; font-size: 0.9rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; border: none; cursor: pointer; text-decoration: none; display: inline-block; transition: all 0.2s; }
        .btn-primary:hover { background: #a93226; transform: translateY(-1px); }
        .btn-secondary { background: transparent; color: #1a1a1a; padding: 0.9rem 2rem; font-family: 'Source Sans 3', sans-serif; font-size: 0.9rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; border: 2px solid #1a1a1a; cursor: pointer; text-decoration: none; display: inline-block; transition: all 0.2s; }
        .btn-secondary:hover { background: #1a1a1a; color: white; }

        .hero-stats { opacity: ${visible ? 1 : 0}; transform: translateY(${visible ? 0 : "20px"}); transition: all 0.8s ease 0.3s; }
        .stats-card { background: white; border: 1px solid rgba(0,0,0,0.08); padding: 2.5rem; position: relative; }
        .stats-card::before { content: "🇨🇭"; position: absolute; top: 1.5rem; right: 1.5rem; font-size: 1.5rem; }
        .stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
        .stat-item {}
        .stat-num { font-family: 'Playfair Display', serif; font-size: 2.8rem; font-weight: 900; color: #c0392b; line-height: 1; }
        .stat-label { font-family: 'Source Sans 3', sans-serif; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: #888; margin-top: 0.3rem; }
        .ticker { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,0.08); display: flex; gap: 1.5rem; overflow: hidden; font-family: 'Source Sans 3', sans-serif; font-size: 0.8rem; color: #888; }
        .ticker-item { white-space: nowrap; display: flex; align-items: center; gap: 0.4rem; }
        .ticker-dot { width: 4px; height: 4px; background: #c0392b; border-radius: 50%; flex-shrink: 0; }

        .section { max-width: 1100px; margin: 0 auto; padding: 5rem 2rem; }
        .section-eyebrow { font-family: 'Source Sans 3', sans-serif; font-size: 0.7rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: #c0392b; margin-bottom: 0.8rem; }
        .section-title { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 3.5vw, 2.8rem); font-weight: 900; line-height: 1.12; letter-spacing: -0.02em; margin-bottom: 0.8rem; }
        .section-title em { font-style: italic; color: #c0392b; }
        .section-sub { font-family: 'Source Sans 3', sans-serif; font-size: 1rem; color: #777; margin-bottom: 3rem; }

        .areas-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(0,0,0,0.08); border: 1px solid rgba(0,0,0,0.08); }
        .area-card { background: white; padding: 2rem; cursor: pointer; transition: all 0.2s; }
        .area-card:hover { background: #fdf3f2; }
        .area-icon { font-size: 1.6rem; margin-bottom: 1rem; }
        .area-title { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; color: #111; }
        .area-desc { font-family: 'Source Sans 3', sans-serif; font-size: 0.85rem; color: #888; line-height: 1.5; }

        .divider { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
        .divider-line { border: none; border-top: 1px solid rgba(0,0,0,0.1); }

        .salarios-list { display: flex; flex-direction: column; gap: 0; border: 1px solid rgba(0,0,0,0.08); background: white; }
        .salario-row { display: flex; align-items: center; justify-content: space-between; padding: 1.4rem 2rem; border-bottom: 1px solid rgba(0,0,0,0.06); transition: background 0.15s; cursor: default; }
        .salario-row:last-child { border-bottom: none; }
        .salario-row:hover { background: #fdf9f8; }
        .salario-info {}
        .salario-rol { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: #111; }
        .salario-sector { font-family: 'Source Sans 3', sans-serif; font-size: 0.8rem; color: #999; margin-top: 0.15rem; }
        .salario-rango { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: #c0392b; letter-spacing: -0.02em; }

        .testimonios-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
        .testimonio { background: white; border: 1px solid rgba(0,0,0,0.08); padding: 2rem; position: relative; }
        .testimonio::before { content: "\u201C"; font-family: 'Playfair Display', serif; font-size: 4rem; color: #c0392b; opacity: 0.15; position: absolute; top: 0.5rem; left: 1.2rem; line-height: 1; }
        .testimonio-texto { font-family: 'Source Sans 3', sans-serif; font-size: 0.92rem; line-height: 1.7; color: #444; font-style: italic; margin-bottom: 1.5rem; }
        .testimonio-nombre { font-family: 'Playfair Display', serif; font-size: 0.95rem; font-weight: 700; color: #111; }
        .testimonio-cargo { font-family: 'Source Sans 3', sans-serif; font-size: 0.78rem; color: #999; margin-top: 0.2rem; }

        .cta-section { background: #111; color: white; padding: 5rem 2rem; text-align: center; }
        .cta-inner { max-width: 600px; margin: 0 auto; }
        .cta-title { font-family: 'Playfair Display', serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; line-height: 1.1; margin-bottom: 1rem; }
        .cta-title em { font-style: italic; color: #e74c3c; }
        .cta-sub { font-family: 'Source Sans 3', sans-serif; font-size: 1rem; color: #aaa; margin-bottom: 2.5rem; line-height: 1.6; }
        .cta-form { display: flex; gap: 0; max-width: 440px; margin: 0 auto; }
        .cta-input { flex: 1; padding: 0.9rem 1.2rem; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white; font-family: 'Source Sans 3', sans-serif; font-size: 0.9rem; outline: none; }
        .cta-input::placeholder { color: rgba(255,255,255,0.4); }
        .cta-btn { background: #c0392b; color: white; border: none; padding: 0.9rem 1.5rem; font-family: 'Source Sans 3', sans-serif; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; white-space: nowrap; transition: background 0.2s; }
        .cta-btn:hover { background: #a93226; }

        footer { background: #faf9f7; border-top: 1px solid rgba(0,0,0,0.1); padding: 3rem 2rem; }
        .footer-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1.5rem; }
        .footer-logo { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; }
        .footer-logo span { color: #c0392b; }
        .footer-links { display: flex; gap: 2rem; }
        .footer-links a { font-family: 'Source Sans 3', sans-serif; font-size: 0.82rem; color: #888; text-decoration: none; transition: color 0.2s; }
        .footer-links a:hover { color: #c0392b; }
        .footer-copy { font-family: 'Source Sans 3', sans-serif; font-size: 0.78rem; color: #bbb; width: 100%; text-align: center; padding-top: 1.5rem; border-top: 1px solid rgba(0,0,0,0.06); }

        @media (max-width: 768px) {
          .hero-inner { grid-template-columns: 1fr; gap: 2.5rem; }
          .areas-grid { grid-template-columns: repeat(2, 1fr); }
          .testimonios-grid { grid-template-columns: 1fr; }
          .nav-links { display: none; }
          .stats-grid { grid-template-columns: repeat(2, 1fr); }
        }
      `}</style>

      {/* NAV */}
      <nav className="nav">
        <div className="nav-logo">Swiss<span>rus</span></div>
        <div className="nav-links">
          {NAV_LINKS.map(l => (
            <a key={l} href="#" className={l === "Calculadora" ? "nav-cta" : ""}>{l}</a>
          ))}
        </div>
      </nav>

      {/* HERO */}
      <section style={{ background: "linear-gradient(160deg, #faf9f7 60%, #fdf3f2 100%)" }}>
        <div className="hero">
          <div className="hero-inner">
            <div className="hero-text">
              <div className="hero-eyebrow">Guía actualizada 2025–2026</div>
              <h1 className="hero-title">
                Todo sobre vivir<br />y trabajar en <em>Suiza</em>
              </h1>
              <p className="hero-subtitle">
                Permisos, salarios, coste de vida, sanidad y pensiones. Información clara, sin letra pequeña ni muros de pago.
              </p>
              <div className="hero-btns">
                <a href="#areas" className="btn-primary">Explorar guías →</a>
                <a href="#" onClick={(e) => { e.preventDefault(); if (onNavigate) onNavigate("calculadora"); }} className="btn-secondary">CALCULA CUANTO GANARAS EN SUIZA</a>
              </div>
            </div>

            <div className="hero-stats">
              <div className="stats-card">
                <div className="stats-grid">
                  <div className="stat-item">
                    <div className="stat-num">~100k</div>
                    <div className="stat-label">Españoles en Suiza</div>
                  </div>
                  <div className="stat-item">
                    <div className="stat-num">26</div>
                    <div className="stat-label">Cantones</div>
                  </div>
                  <div className="stat-item">
                    <div className="stat-num">6–8k</div>
                    <div className="stat-label">CHF salario medio</div>
                  </div>
                  <div className="stat-item">
                    <div className="stat-num">4</div>
                    <div className="stat-label">Permisos principales</div>
                  </div>
                </div>
                <div className="ticker">
                  <span className="ticker-item"><span className="ticker-dot"></span>Permiso B: 5 años renovable</span>
                  <span className="ticker-item"><span className="ticker-dot"></span>LAMal obligatoria</span>
                  <span className="ticker-item"><span className="ticker-dot"></span>Recupera tu 2.º pilar</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* AREAS */}
      <section id="areas" className="section">
        <div className="section-eyebrow">Áreas principales</div>
        <h2 className="section-title">¿Qué quieres <em>saber?</em></h2>
        <p className="section-sub">Información organizada por bloques para que encuentres lo que buscas sin perder tiempo.</p>
        <div className="areas-grid">
          {AREAS.map((a) => (
            <div key={a.title} className="area-card" onClick={() => { if (a.page && onNavigate) onNavigate(a.page); }}>
              <div className="area-icon">{a.icon}</div>
              <div className="area-title">{a.title}</div>
              <div className="area-desc">{a.desc}</div>
            </div>
          ))}
        </div>
      </section>

      <div className="divider"><hr className="divider-line" /></div>

      {/* SALARIOS */}
      <section className="section">
        <div className="section-eyebrow">Mercado laboral</div>
        <h2 className="section-title">Salarios brutos <em>2025</em></h2>
        <p className="section-sub">Cifras brutas anuales en CHF basadas en datos oficiales del mercado suizo.</p>
        <div className="salarios-list">
          {SALARIOS.map((s) => (
            <div key={s.rol} className="salario-row">
              <div className="salario-info">
                <div className="salario-rol">{s.rol}</div>
                <div className="salario-sector">{s.sector}</div>
              </div>
              <div className="salario-rango">{s.rango}</div>
            </div>
          ))}
        </div>
        <div style={{ marginTop: "1.5rem" }}>
          <a href="#calc" className="btn-primary">CALCULA CUANTO GANARAS EN SUIZA exacto →</a>
        </div>
      </section>

      <div className="divider"><hr className="divider-line" /></div>

      {/* TESTIMONIOS */}
      <section className="section">
        <div className="section-eyebrow">Comunidad</div>
        <h2 className="section-title">Lo que dicen los que <em>ya están aquí</em></h2>
        <p className="section-sub">Experiencias reales de hispanohablantes que dieron el paso.</p>
        <div className="testimonios-grid">
          {TESTIMONIOS.map((t) => (
            <div key={t.nombre} className="testimonio">
              <p className="testimonio-texto">{t.texto}</p>
              <div className="testimonio-nombre">{t.nombre}</div>
              <div className="testimonio-cargo">{t.cargo}</div>
            </div>
          ))}
        </div>
      </section>

      {/* PUBLICIDAD */}
      <section style={{ background: "#fdf9f8", borderTop: "1px solid rgba(0,0,0,0.07)", borderBottom: "1px solid rgba(0,0,0,0.07)", padding: "1.2rem 2rem" }}>
        <div style={{ maxWidth: 1100, margin: "0 auto", display: "flex", alignItems: "center", justifyContent: "space-between", gap: 16, flexWrap: "wrap" }}>
          <div style={{ fontSize: 10, color: "#ccc", textTransform: "uppercase", letterSpacing: "0.1em", fontFamily: "sans-serif", flexShrink: 0 }}>Publicidad</div>
          <div style={{ flex: 1, minWidth: 200 }}>
            <div style={{ fontFamily: "Georgia, serif", fontSize: 15, fontWeight: 700, color: "#111", marginBottom: 2 }}>¿Tu empresa trabaja con hispanohablantes en Suiza?</div>
            <div style={{ fontSize: 12, color: "#999", fontFamily: "sans-serif" }}>Gestoría, seguros, mudanzas, inmobiliaria — llega a miles de lectores cualificados</div>
          </div>
          <a href="mailto:hola@swissrus.ch" style={{ background: "#111", color: "white", padding: "0.6rem 1.4rem", fontSize: 12, fontWeight: 700, textDecoration: "none", fontFamily: "sans-serif", letterSpacing: "0.05em", textTransform: "uppercase", flexShrink: 0 }}>
            Anúnciate →
          </a>
        </div>
      </section>

      {/* TELEGRAM + CTA */}
      <section className="cta-section">
        <div className="cta-inner" style={{ maxWidth: 800 }}>
          <h2 className="cta-title">Únete a la <em>comunidad</em></h2>
          <p className="cta-sub">Canales de Telegram con noticias, ofertas de empleo, coches y vida en Suiza. Directo a tu móvil.</p>

          <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(240px, 1fr))", gap: 12, marginBottom: 32, textAlign: "left" }}>
            <a href="https://t.me/cochesensuiza" target="_blank" rel="noopener noreferrer"
              style={{ background: "rgba(255,255,255,0.06)", border: "1px solid rgba(255,255,255,0.12)", borderRadius: 4, padding: "1.2rem 1.4rem", textDecoration: "none", color: "inherit", display: "flex", gap: 12, alignItems: "flex-start" }}
            >
              <div style={{ fontSize: 28, flexShrink: 0 }}>🚗</div>
              <div>
                <div style={{ fontFamily: "Georgia, serif", fontSize: 15, fontWeight: 700, color: "white", marginBottom: 4 }}>Coches en Suiza</div>
                <div style={{ fontSize: 12, color: "#e74c3c", fontFamily: "sans-serif", fontWeight: 600, marginBottom: 6 }}>@cochesensuiza</div>
                <div style={{ fontSize: 12, color: "#aaa", fontFamily: "sans-serif", lineHeight: 1.5 }}>Compraventa de coches entre particulares. Ofertas diarias.</div>
              </div>
            </a>
            <a href="https://t.me/swissrus_ch" target="_blank" rel="noopener noreferrer"
              style={{ background: "rgba(255,255,255,0.06)", border: "1px solid rgba(255,255,255,0.12)", borderRadius: 4, padding: "1.2rem 1.4rem", textDecoration: "none", color: "inherit", display: "flex", gap: 12, alignItems: "flex-start" }}
            >
              <div style={{ fontSize: 28, flexShrink: 0 }}>🇨🇭</div>
              <div>
                <div style={{ fontFamily: "Georgia, serif", fontSize: 15, fontWeight: 700, color: "white", marginBottom: 4 }}>Swissrus</div>
                <div style={{ fontSize: 12, color: "#3498db", fontFamily: "sans-serif", fontWeight: 600, marginBottom: 6 }}>@swissrus_ch</div>
                <div style={{ fontSize: 12, color: "#aaa", fontFamily: "sans-serif", lineHeight: 1.5 }}>Canal oficial. Noticias, leyes, empleo y vida en Suiza.</div>
              </div>
            </a>
          </div>

          <p style={{ fontFamily: "sans-serif", fontSize: 13, color: "#777", marginBottom: 12 }}>O recibe novedades por email:</p>
          <div className="cta-form">
            <input className="cta-input" type="email" placeholder="tu@email.com" />
            <button className="cta-btn">Suscribirme →</button>
          </div>
        </div>
      </section>

      {/* FOOTER */}
      <footer>
        <div className="footer-inner">
          <div className="footer-logo">Swiss<span>rus</span></div>
          <div className="footer-links">
            {["Permisos", "Salarios", "Sanidad", "Pensiones", "Aviso legal"].map(l => (
              <a key={l} href="#">{l}</a>
            ))}
